<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inside The Baseline</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --clay: #C8553D;
    --clay-dark: #A03E2A;
    --cream: #F5F0E8;
    --ink: #1A1714;
    --ink-light: #3D3630;
    --sand: #E8DFD0;
    --green: #2D5016;
    --green-light: #4A7A28;
    --white: #FDFAF5;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: 'DM Sans', sans-serif;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 48px;
    background: var(--cream);
    border-bottom: 1px solid rgba(26,23,20,0.12);
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-logo span { color: var(--clay); }

  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-light);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--clay); }

  .nav-cta {
    background: var(--clay);
    color: var(--white) !important;
    padding: 10px 22px;
    border-radius: 2px;
    font-size: 0.75rem !important;
    letter-spacing: 0.12em !important;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: var(--clay-dark) !important; color: var(--white) !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 72px;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 48px 80px 80px;
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--clay);
  }

  .hero-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 5vw, 5.5rem);
    font-weight: 900;
    line-height: 1.0;
    color: var(--ink);
    margin-bottom: 28px;
  }

  .hero-headline em {
    font-style: italic;
    color: var(--clay);
  }

  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink-light);
    max-width: 420px;
    margin-bottom: 48px;
    font-weight: 300;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--clay);
    color: var(--white);
    padding: 16px 36px;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }

  .btn-primary:hover {
    background: var(--clay-dark);
    transform: translateY(-1px);
  }

  .btn-secondary {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-secondary:hover { color: var(--clay); border-color: var(--clay); }

  .hero-stats {
    display: flex;
    gap: 40px;
    margin-top: 64px;
    padding-top: 40px;
    border-top: 1px solid rgba(26,23,20,0.12);
  }

  .stat-item {}
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-top: 4px;
    font-weight: 400;
  }

  .hero-right {
    background: var(--ink);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .court-graphic {
    position: absolute;
    inset: 0;
    opacity: 0.08;
  }

  .hero-right-content {
    position: relative;
    z-index: 2;
    padding: 48px;
    width: 100%;
  }

  .featured-issue {
    border: 1px solid rgba(245,240,232,0.15);
    padding: 40px;
    position: relative;
  }

  .featured-issue::before {
    content: 'LATEST ISSUE';
    position: absolute;
    top: -10px;
    left: 24px;
    background: var(--clay);
    color: var(--white);
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    padding: 3px 10px;
  }

  .issue-num {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(245,240,232,0.4);
    margin-bottom: 16px;
  }

  .issue-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .issue-excerpt {
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(245,240,232,0.6);
    font-weight: 300;
    margin-bottom: 28px;
  }

  .issue-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid rgba(245,240,232,0.2);
    color: rgba(245,240,232,0.5);
  }

  .tag.hot { border-color: var(--clay); color: var(--clay); }

  .read-link {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clay);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
    transition: gap 0.2s;
  }

  .read-link:hover { gap: 14px; }

  /* ── TICKER ── */
  .ticker {
    background: var(--clay);
    color: var(--white);
    padding: 12px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .ticker-inner {
    display: inline-flex;
    gap: 0;
    animation: ticker 30s linear infinite;
  }

  .ticker-item {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0 40px;
    border-right: 1px solid rgba(255,255,255,0.3);
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ── ABOUT ── */
  .about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }

  .about-left {
    background: var(--green);
    padding: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .about-left::after {
    content: '◉';
    position: absolute;
    bottom: -40px;
    right: -20px;
    font-size: 180px;
    color: rgba(255,255,255,0.04);
    line-height: 1;
  }

  .about-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.5);
    margin-bottom: 24px;
  }

  .about-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: 24px;
  }

  .about-headline em {
    font-style: italic;
    color: rgba(245,240,232,0.6);
  }

  .about-body {
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(245,240,232,0.7);
    font-weight: 300;
    max-width: 380px;
  }

  .about-right {
    background: var(--sand);
    padding: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
  }

  .coverage-item {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(26,23,20,0.1);
  }

  .coverage-item:last-child { border-bottom: none; padding-bottom: 0; }

  .coverage-icon {
    width: 40px;
    height: 40px;
    border: 1px solid var(--clay);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1rem;
  }

  .coverage-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--ink);
  }

  .coverage-desc {
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--ink-light);
    font-weight: 300;
  }

  /* ── ISSUES ── */
  .issues {
    padding: 100px 80px;
    background: var(--white);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 56px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(26,23,20,0.12);
  }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--ink);
  }

  .view-all {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-light);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: color 0.2s;
  }

  .view-all:hover { color: var(--clay); }

  .issues-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .issue-card {
    background: var(--cream);
    padding: 40px 36px;
    position: relative;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .issue-card:hover { background: var(--sand); }

  .issue-card-num {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: var(--clay);
    margin-bottom: 20px;
  }

  .issue-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 16px;
    color: var(--ink);
  }

  .issue-card-excerpt {
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--ink-light);
    font-weight: 300;
    margin-bottom: 28px;
  }

  .issue-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .issue-card-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(26,23,20,0.4);
  }

  .issue-card-arrow {
    color: var(--clay);
    font-size: 1rem;
    transition: transform 0.2s;
  }

  .issue-card:hover .issue-card-arrow { transform: translateX(4px); }

  /* ── ABOUT ME ── */
  .about-me {
    padding: 100px 80px;
    background: var(--cream);
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 80px;
    align-items: center;
  }

  .about-me-photo-wrap {
    position: relative;
  }

  .about-me-photo {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(15%);
  }

  .about-me-photo-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--sand);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    border: 2px dashed rgba(26,23,20,0.15);
    color: rgba(26,23,20,0.3);
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .about-me-photo-placeholder span {
    font-size: 2rem;
  }

  .about-me-photo-accent {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 100%;
    height: 100%;
    border: 2px solid var(--clay);
    z-index: -1;
  }

  .about-me-content {}

  .about-me-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .about-me-label::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--clay);
  }

  .about-me-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 900;
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .about-me-title {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-light);
    margin-bottom: 32px;
    opacity: 0.6;
  }

  .about-me-bio {
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--ink-light);
    font-weight: 300;
    margin-bottom: 40px;
  }

  .about-me-bio strong {
    color: var(--ink);
    font-weight: 500;
  }

  .about-me-credentials {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(26,23,20,0.12);
  }

  .credential {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(26,23,20,0.08);
  }

  .credential-icon {
    width: 32px;
    height: 32px;
    background: var(--clay);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .credential-text {
    font-size: 0.82rem;
    color: var(--ink-light);
    font-weight: 400;
  }

  .credential-text strong {
    color: var(--ink);
    font-weight: 500;
  }

  /* ── NEWSLETTER CTA ── */
  .newsletter-cta {
    background: var(--ink);
    padding: 100px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .newsletter-cta::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    border: 1px solid rgba(200,85,61,0.15);
    border-radius: 50%;
  }

  .newsletter-cta::after {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 280px;
    height: 280px;
    border: 1px solid rgba(200,85,61,0.1);
    border-radius: 50%;
  }

  .cta-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 20px;
  }

  .cta-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3vw, 3.2rem);
    font-weight: 900;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .cta-headline em { font-style: italic; color: var(--clay); }

  .cta-sub {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(245,240,232,0.5);
    font-weight: 300;
  }

  .cta-form {
    position: relative;
    z-index: 2;
  }

  .cta-form-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-input {
    background: rgba(245,240,232,0.06);
    border: 1px solid rgba(245,240,232,0.15);
    color: var(--cream);
    padding: 16px 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-input::placeholder { color: rgba(245,240,232,0.3); }
  .form-input:focus { border-color: var(--clay); }

  .form-btn {
    background: var(--clay);
    color: var(--white);
    border: none;
    padding: 16px 36px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s;
    width: 100%;
  }

  .form-btn:hover { background: var(--clay-dark); }

  .form-note {
    font-size: 0.7rem;
    color: rgba(245,240,232,0.3);
    letter-spacing: 0.05em;
    text-align: center;
  }

  /* ── SOCIALS ── */
  .socials {
    background: var(--sand);
    padding: 64px 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .socials-left {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--ink);
  }

  .socials-left span { font-style: italic; color: var(--clay); }

  .social-links {
    display: flex;
    gap: 16px;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border: 1px solid rgba(26,23,20,0.15);
    text-decoration: none;
    color: var(--ink);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.2s;
    background: var(--white);
  }

  .social-link:hover {
    background: var(--clay);
    color: var(--white);
    border-color: var(--clay);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--ink);
    padding: 48px 80px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }

  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 1rem;
    color: var(--cream);
    letter-spacing: 0.04em;
  }

  .footer-logo span { color: var(--clay); }

  .footer-tagline {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.3);
    margin-top: 4px;
  }

  .footer-right {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(245,240,232,0.3);
    text-align: right;
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow { animation: fadeUp 0.6s ease forwards; }
  .hero-headline { animation: fadeUp 0.6s 0.1s ease both; }
  .hero-sub { animation: fadeUp 0.6s 0.2s ease both; }
  .hero-actions { animation: fadeUp 0.6s 0.3s ease both; }
  .hero-stats { animation: fadeUp 0.6s 0.4s ease both; }
  .featured-issue { animation: fadeUp 0.8s 0.2s ease both; }

  /* ── COURT SVG LINES ── */
  .court-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">Inside The <span>Baseline</span></a>
  <ul class="nav-links">
    <li><a href="#issues">Newsletter</a></li>
    <li><a href="#podcast">Podcast</a></li>
